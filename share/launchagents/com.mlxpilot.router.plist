<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mlxpilot.router</string>

    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/.mlxlm/venv/bin/python</string>
        <string>__HOME__/.mlxlm/router.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__HOME__/.mlxlm</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key><false/>
        <key>Crashed</key><true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>__HOME__/.mlxlm/logs/router.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.mlxlm/logs/router.log</string>

    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key><integer>4096</integer>
    </dict>
</dict>
</plist>
